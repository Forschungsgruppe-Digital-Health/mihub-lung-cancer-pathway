    <bpmn:textAnnotation id="TextAnnotation_0qqtisd">
      <bpmn:text>Administrative Daten: Patientendaten, anmeldende Person, gewünschte Teilnehmende; Medizinische Daten: Anamnese, Erkrankung, Staging, Typisierung, Grading, Ergebnisse aus Bildgebung/Labor/Pathologie, durchgeführte Therapien</bpmn:text>
    </bpmn:textAnnotation>
