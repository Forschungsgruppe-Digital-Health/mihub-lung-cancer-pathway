    <bpmn:textAnnotation id="TextAnnotation_042gz3u">
      <bpmn:text>Diskussion und Entscheidungsfindung: weiteres Vorgehen Therapie/keine Therapie; falls nötig noch fehlende Diagnostik; falls nötig Wiedervorstellung; bei Eignung Studienempfehlung</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0fk0lek" sourceRef="Activity_1e4jmjc" targetRef="TextAnnotation_042gz3u" />
    <bpmn:textAnnotation id="TextAnnotation_02vldql">
      <bpmn:text>Teilnehmende: Pathologie, Radiologie, tumorspezifische Fachabteilungen, gegebenenfalls weitere Teilnehmende; Darstellung des Falls, falls nötig Darstellung von Pathologie/Bildgebung</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_08afk0j" sourceRef="Activity_1e4jmjc" targetRef="TextAnnotation_02vldql" />
    <bpmn:textAnnotation id="TextAnnotation_1er2nm3">
