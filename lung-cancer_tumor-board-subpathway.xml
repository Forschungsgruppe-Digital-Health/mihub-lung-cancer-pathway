  <bpmn:collaboration id="Collaboration_00djj31">
    <bpmn:participant id="Participant_1qylwsq" name="Standard-Tumorboard (TB) - Lungenkrebs"
      processRef="Process_e2faa7c4-7c7e-4408-82ce-89d081ca8a1b">
      <bpmn:extensionElements>
        <i18n:translation target="@name" xml:lang="en">Standard Tumor Board (TB) - Lung Cancer</i18n:translation>
        <i18n:translation target="@name" xml:lang="de">Standard-Tumorboard (TB) - Lungenkrebs</i18n:translation>
      </bpmn:extensionElements>
    </bpmn:participant>
    <bpmn:textAnnotation id="TextAnnotation_02vldql">
      <bpmn:extensionElements>
        <i18n:translation target="@text" xml:lang="en">participants are all main cooperation
          partners of the LC CCCN: pneumology, thoracic surgery, medical oncology, radiotherapy,
          pathology, radiology, nuclear medicine; other partners and specialties are included as
          needed [LC SoS 1.2.3.B]</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">Teilnehmende sind alle wesentlichen
          Kooperationspartner des LC CCCN: Pneumologie, Thoraxchirurgie, medizinische Onkologie,
          Strahlentherapie, Pathologie, Radiologie, Nuklearmedizin; weitere Partner und
          Fachrichtungen werden bei Bedarf einbezogen [LC SoS 1.2.3.B]</i18n:translation>
      </bpmn:extensionElements>
      <bpmn:text>Teilnehmende sind alle wesentlichen Kooperationspartner des LC CCCN: Pneumologie,
        Thoraxchirurgie, medizinische Onkologie, Strahlentherapie, Pathologie, Radiologie,
        Nuklearmedizin; weitere Partner und Fachrichtungen werden bei Bedarf einbezogen [LC SoS
        1.2.3.B]</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_08afk0j" sourceRef="Activity_1phtl9y"
      targetRef="TextAnnotation_02vldql" />
    <bpmn:textAnnotation id="TextAnnotation_1er2nm3">
      <bpmn:extensionElements>
        <i18n:translation target="@text" xml:lang="en">main patient and treatment data are to be
          compiled in writing and made available to TB participants; a case presentation at the TB
          must include a comprehensive visual presentation of all relevant diagnostic results [LC
          SoS 1.2.3.A]; a pre-appraisal of suitable study patients is undertaken [LC SoS 1.2.3.C];
          invitation of TB participants</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">wesentliche Patienten- und Behandlungsdaten
          sind schriftlich zusammenzustellen und den TB-Teilnehmenden zur Verfügung zu stellen; eine
          Fallvorstellung im TB muss eine umfassende visuelle Darstellung aller relevanten
          diagnostischen Ergebnisse enthalten [LC SoS 1.2.3.A]; eine Vorprüfung geeigneter
          Studienpatienten wird durchgeführt [LC SoS 1.2.3.C]; Einladung der TB-Teilnehmenden</i18n:translation>
      </bpmn:extensionElements>
      <bpmn:text>wesentliche Patienten- und Behandlungsdaten
        sind schriftlich zusammenzustellen und den TB-Teilnehmenden zur Verfügung zu stellen; eine
        Fallvorstellung im TB muss eine umfassende visuelle Darstellung aller relevanten
        diagnostischen Ergebnisse enthalten [LC SoS 1.2.3.A]; eine Vorprüfung geeigneter
        Studienpatienten wird durchgeführt [LC SoS 1.2.3.C]; Einladung der TB-Teilnehmenden</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1vzl3a6" sourceRef="Activity_1phtl9y"
      targetRef="TextAnnotation_1er2nm3" />
    <bpmn:textAnnotation id="TextAnnotation_042gz3u">
      <bpmn:extensionElements>
        <i18n:translation target="@text" xml:lang="en">demonstration imaging material [LC SoS
          1.2.3.E]; presentation, discussion and decision-making: preparation of interdisciplinary
          treatment plan [LC SoS 1.2.3.F]; documentation of participation [LC SoS 1.2.3.B]; if
          necessary: still missing diagnostics OR re-presentation; if suitable: study recommendation</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">Demonstration des Bildmaterials [LC SoS
          1.2.3.E]; Vorstellung, Diskussion und Entscheidungsfindung: Erstellung eines
          interdisziplinären Behandlungsplans [LC SoS 1.2.3.F]; Dokumentation der Teilnahme [LC SoS
          1.2.3.B]; falls erforderlich: noch fehlende Diagnostik ODER Wiedervorstellung; falls
          geeignet: Studienempfehlung</i18n:translation>
      </bpmn:extensionElements>
      <bpmn:text>Demonstration des Bildmaterials [LC SoS 1.2.3.E]; Vorstellung, Diskussion und
        Entscheidungsfindung: Erstellung eines interdisziplinären Behandlungsplans [LC SoS 1.2.3.F];
        Dokumentation der Teilnahme [LC SoS 1.2.3.B]; falls erforderlich: noch fehlende Diagnostik
        ODER Wiedervorstellung; falls geeignet: Studienempfehlung</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0fk0lek" sourceRef="Activity_1e4jmjc"
      targetRef="TextAnnotation_042gz3u" />
    <bpmn:textAnnotation id="TextAnnotation_0qqtisd">
      <bpmn:extensionElements>
        <i18n:translation target="@text" xml:lang="en">administrative data: patient data,
          registering person, desired participants;
          medical data: anamnesis, disease, staging, typing, grading, results from imaging/
          laboratory/ pathology, therapies carried out;
          patient-related imaging material (e.g., imaging scans, pathology reports, and laboratory
          results) [LC SoS 1.2.3.A]</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">Administrative Daten: Patientendaten,
          anmeldende Person, gewünschte Teilnehmende;
          medizinische Daten: Anamnese, Erkrankung, Staging, Typisierung, Grading, Ergebnisse aus
          Bildgebung/Labor/Pathologie, durchgeführte Therapien;
          patientenbezogenes Bildmaterial (z. B. Bildgebung, Pathologiebefunde und Laborergebnisse)
          [LC SoS 1.2.3.A]</i18n:translation>
      </bpmn:extensionElements>
      <bpmn:text>Administrative Daten: Patientendaten,
        anmeldende Person, gewünschte Teilnehmende;
        medizinische Daten: Anamnese, Erkrankung, Staging, Typisierung, Grading, Ergebnisse aus
        Bildgebung/Labor/Pathologie, durchgeführte Therapien;
        patientenbezogenes Bildmaterial (z. B. Bildgebung, Pathologiebefunde und Laborergebnisse)
        [LC SoS 1.2.3.A]</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1kr0h9z" sourceRef="DataObjectReference_1mlu0z0"
      targetRef="TextAnnotation_0qqtisd" />
    <bpmn:textAnnotation id="TextAnnotation_0cqjbdt">
      <bpmn:extensionElements>
        <i18n:translation target="@text" xml:lang="en">all patients with a first manifestation
          (primary cases), a new recurrence or remote metastasis, are presented at the tumour board
          before treatment (pre-therapeutic tumour board presentation) [LC SoS 1.2.2.D]</i18n:translation>
        <i18n:translation target="@text" xml:lang="de">alle Patienten mit Erstmanifestation
          (Primärfälle), neuem Rezidiv oder Fernmetastase werden vor der Behandlung im Tumorboard
          vorgestellt (prätherapeutische Tumorboard-Vorstellung) [LC SoS 1.2.2.D]</i18n:translation>
      </bpmn:extensionElements>
      <bpmn:text>alle Patienten mit Erstmanifestation
        (Primärfälle), neuem Rezidiv oder Fernmetastase werden vor der Behandlung im Tumorboard
        vorgestellt (prätherapeutische Tumorboard-Vorstellung) [LC SoS 1.2.2.D]</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1vslqwx" associationDirection="None" sourceRef="StartEvent_1"
